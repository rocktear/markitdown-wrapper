""".strip())


# ─── 主入口 ────────────────────────────────────────────
def main():
    # 解析参数
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("items", nargs="*", help="Files or URLs to convert")
    parser.add_argument("--force", "-f", action="store_true", help="Overwrite existing")
    parser.add_argument("--help", "-h", action="store_true", help="Show help")
    args, _ = parser.parse_known_args()

    if args.help or not args.items:
        print_help()
        sys.exit(0)

    force = args.force or os.environ.get("FORCE") == "1"

    # 确保输出目录存在
    OUTPUT_BASE.mkdir(parents=True, exist_ok=True)

    print(f"{Color.BLUE}╔{'═' * 40}╗{Color.NC}")
    print(f"{Color.BLUE}║   doc2md — 万能→Markdown 引擎        ║{Color.NC}")
    if LLM_API_KEY:
        print(f"{Color.BLUE}║   LLM 描述: {LLM_MODEL}{' ' * (28 - len(LLM_MODEL))}║{Color.NC}")
    print(f"{Color.BLUE}║   输出 → {OUTPUT_BASE}{Color.NC}")
    print(f"{Color.BLUE}╚{'═' * 40}╝{Color.NC}")
    print()

    items = args.items
    total = len(items)
    success = 0
    failed = 0

    for item in items:
        total_processed = success + failed + 1
        print(f"  [{total_processed}/{total}] ", end="")
        if convert(item, force=force):
            success += 1
        else:
            failed += 1

    print()
    print(f"{Color.BLUE}┌{'─' * 40}┐{Color.NC}")
    print(f"{Color.BLUE}│ 总计: {total}  │  ✓ {success}  │  ✗ {failed}               │{Color.NC}")
    print(f"{Color.BLUE}└{'─' * 40}┘{Color.NC}")

    if success > 0:
        print()
        print(f"{Color.CYAN}💡 转换完成！建议:{Color.NC}")
        print("   qmd update   # 更新 wiki 索引")


if __name__ == "__main__":
    main()
